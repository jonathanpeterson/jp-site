{
  "name": "jp-site",
  "scripts": {
    "dev": "concurrently \"hugo server\" \"tailwindcss -i ./_vendor/github.com/jpanther/congo/v2/assets/css/main.css -o ./assets/css/compiled/main.css --watch\"",
    "build:css": "NODE_ENV=production tailwindcss -i ./_vendor/github.com/jpanther/congo/v2/assets/css/main.css -o ./assets/css/compiled/main.css --minify"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "concurrently": "^8.2.2",
    "tailwindcss": "^3.4.19"
  }
}
