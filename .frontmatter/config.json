{
  "$schema": "https://beta.frontmatter.codes/schema/config.json",
  "frontMatter.projectTitle": "JP Site",
  "frontMatter.framework.id": "astro-starlight",
  "frontMatter.staticSiteGenerator": "astro",
  "frontMatter.content.pageFolders": [
    {
      "title": "Writing",
      "path": "[[workspace]]/src/content/writing"
    },
    {
      "title": "DJ",
      "path": "[[workspace]]/src/content/dj"
    }
  ],
  "frontMatter.taxonomy.contentTypes": [
    {
      "name": "writing",
      "pageBundle": false,
      "previewPath": "/writing",
      "fields": [
        {
          "name": "title",
          "type": "string",
          "single": true,
          "required": true
        },
        {
          "name": "description",
          "type": "string",
          "single": true,
          "required": true
        },
        {
          "name": "date",
          "type": "datetime",
          "required": true
        },
        {
          "name": "tags",
          "type": "tags",
          "required": true
        }
      ]
    },
    {
      "name": "dj",
      "pageBundle": false,
      "previewPath": "/dj",
      "fields": [
        {
          "name": "title",
          "type": "string",
          "single": true,
          "required": true
        },
        {
          "name": "description",
          "type": "string",
          "single": true,
          "required": true
        },
        {
          "name": "date",
          "type": "datetime",
          "required": true
        },
        {
          "name": "tags",
          "type": "tags",
          "required": true
        }
      ]
    }
  ],
  "frontMatter.taxonomy.tags": [
    "music",
    "opinion",
    "personal",
    "professional",
    "projects",
    "tech-history",
    "web"
  ],
  "frontMatter.taxonomy.categories": []
}
