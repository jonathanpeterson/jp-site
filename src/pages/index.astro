---
import BaseLayout from '../components/layout/BaseLayout.astro';
import ContentIcon from '../components/ContentIcon.astro';
import { getRecentPosts, getPostUrl } from '../utils/collections';

const recentPosts = await getRecentPosts(5);
---

<BaseLayout title="Jonathan Peterson" isHome={true}>
  <div class="jp-home-banner">
    <img src="/images/made_in_atl.jpg" alt="Made in Atlanta" />
  </div>

  <div class="jp-hero">
    <h1 class="jp-hero-title">Thirty years building righteous solutions to wicked problems.</h1>
    <p class="jp-hero-sub">Still taking requests.</p>
  </div>

  <section class="jp-paths">
    <div class="jp-path">
      <h2>Writing</h2>
      <p>Technology, methodology and product craft, and my little window into the strange history of the internet. Observations on technology, AI, culture, and what the people building things owe the people affected by them.</p>
      <a class="jp-cta" href="/writing/">Writing →</a>
    </div>

    <div class="jp-path">
      <h2>Projects</h2>
      <p>Things I'm currently building — a macOS notification utility, a local news aggregator for Atlanta, a personal interruption manager — and thirty years of portfolio.</p>
      <a class="jp-cta" href="/projects/">Projects →</a>
    </div>

    <div class="jp-path">
      <h2>Jonny Spins</h2>
      <p>I spin Funk, R&amp;B, Disco, 80s, Old School Hip-Hop, Classic House, Deep House, Dance Pop — from the 70s to today</p>
      <a class="jp-cta" href="/dj/">Dance Music for Old People&nbsp;→</a>
    </div>

    {recentPosts.length > 0 && (
      <div class="jp-recent">
        <h2>Recently</h2>
        <div class="jp-recent-posts">
          {recentPosts.map(post => (
            <div class="jp-recent-post">
              <ContentIcon tags={post.data.tags} />
              <time class="jp-recent-date" datetime={post.data.date.toISOString().split('T')[0]}>
                {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
              <a href={getPostUrl(post)}>{post.data.title}</a>
            </div>
          ))}
        </div>
      </div>
    )}
  </section>
</BaseLayout>
