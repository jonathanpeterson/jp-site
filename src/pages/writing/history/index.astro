---
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import PostList from '../../../components/PostList.astro';
import { getHistoryPosts } from '../../../utils/collections';

const posts = await getHistoryPosts();
---

<BaseLayout title="Internet History" description="First-person accounts from the early years of the web.">
  <h1 class="jp-page-title">Internet History</h1>
  <p class="jp-section-desc text-neutral-600 dark:text-neutral-400 mb-6">
    First-person accounts from the early years of the web — what it felt like to build things when the medium was new enough that nobody knew what they were doing.
  </p>

  <PostList posts={posts} />
</BaseLayout>
