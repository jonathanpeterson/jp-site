---
import PostItem from './PostItem.astro';
import { getPostUrl } from '../utils/collections';

interface Props {
  posts: any[];
}

const { posts } = Astro.props;
---

<ul class="jp-post-list">
  {posts.map(post => (
    <PostItem
      title={post.data.title}
      href={getPostUrl(post)}
      date={post.data.date}
      description={post.data.description}
      tags={post.data.tags}
    />
  ))}
</ul>
