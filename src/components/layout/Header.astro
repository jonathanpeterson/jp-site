---
interface Props {
  isHome?: boolean;
}
const { isHome = false } = Astro.props;

const navLinks = [
  { name: 'About', href: '/about/' },
  { name: 'Writing', href: '/writing/' },
  { name: 'Projects', href: '/projects/' },
  { name: 'DJ', href: '/dj/' },
];
---

<header class="py-6 font-semibold text-neutral-900 dark:text-neutral-100 sm:py-10 print:hidden">
  <nav class="flex items-start justify-between">
    <!-- Avatar + site title -->
    <div class="flex flex-row items-center gap-4">
      <a href="/" aria-label="Home">
        <img
          src="/images/myhead-charcoal.png"
          alt="Jonathan Peterson"
          class="jp-avatar"
        />
      </a>
      <span style="padding-left: 0.75rem">
        <a href="/" class="text-lg font-bold text-neutral-900 dark:text-neutral-100">
          Jonathan Peterson
        </a>
      </span>
    </div>

    <!-- Right side: main nav + contact bar -->
    <div class="flex flex-col items-end gap-2">
      <!-- Main nav -->
      <ul class="flex list-none flex-col text-end sm:flex-row gap-0 sm:gap-6">
        {navLinks.map(link => (
          <li>
            <a href={link.href} class="text-sm font-semibold text-neutral-700 dark:text-neutral-300 hover:text-neutral-900 dark:hover:text-neutral-100">
              {link.name}
            </a>
          </li>
        ))}
        <!-- Dark mode toggle -->
        <li>
          <button
            id="theme-toggle"
            type="button"
            aria-label="Toggle dark mode"
            class="text-sm font-semibold text-neutral-700 dark:text-neutral-300 hover:text-neutral-900 dark:hover:text-neutral-100 cursor-pointer"
          >
            <span class="dark:hidden">☾</span>
            <span class="hidden dark:inline">☀</span>
          </button>
        </li>
      </ul>

      <!-- Contact bar -->
      <div class="flex items-center gap-4 text-xs text-neutral-500 dark:text-neutral-400 font-normal">
        <a href="mailto:jonathan@jonathan-peterson.com" class="flex items-center gap-1 hover:text-neutral-700 dark:hover:text-neutral-200">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5" aria-hidden="true">
            <path d="M3 4a2 2 0 0 0-2 2v1.161l8.441 4.221a1.25 1.25 0 0 0 1.118 0L19 7.162V6a2 2 0 0 0-2-2H3Z" />
            <path d="m19 8.839-7.77 3.885a2.75 2.75 0 0 1-2.46 0L1 8.839V14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V8.839Z" />
          </svg>
          Email
        </a>
        <a href="https://www.linkedin.com/in/jonathanpeterson/" target="_blank" rel="noopener" class="flex items-center gap-1 hover:text-neutral-700 dark:hover:text-neutral-200">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
        <a href="https://github.com/jonathanpeterson" target="_blank" rel="noopener" class="flex items-center gap-1 hover:text-neutral-700 dark:hover:text-neutral-200">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5" aria-hidden="true">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
          GitHub
        </a>
        <a href="/jonathan-peterson-resume.pdf" class="flex items-center gap-1 hover:text-neutral-700 dark:hover:text-neutral-200">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5" aria-hidden="true">
            <path d="M10.75 2.75a.75.75 0 0 0-1.5 0v8.614L6.295 8.235a.75.75 0 1 0-1.09 1.03l4.25 4.5a.75.75 0 0 0 1.09 0l4.25-4.5a.75.75 0 0 0-1.09-1.03l-2.955 3.129V2.75Z" />
            <path d="M3.5 12.75a.75.75 0 0 0-1.5 0v2.5A2.75 2.75 0 0 0 4.75 18h10.5A2.75 2.75 0 0 0 18 15.25v-2.5a.75.75 0 0 0-1.5 0v2.5c0 .69-.56 1.25-1.25 1.25H4.75c-.69 0-1.25-.56-1.25-1.25v-2.5Z" />
          </svg>
          Resume
        </a>
      </div>
    </div>
  </nav>

  {isHome && (
    <p class="jp-hero-tagline">Product leader. Frustrated artist. Engineer at heart. Enthusiastic DJ for the afterparty.</p>
  )}
</header>

<script>
  const btn = document.getElementById('theme-toggle');
  if (btn) {
    btn.addEventListener('click', () => {
      const html = document.documentElement;
      if (html.classList.contains('dark')) {
        html.classList.remove('dark');
        localStorage.setItem('theme', 'light');
      } else {
        html.classList.add('dark');
        localStorage.setItem('theme', 'dark');
      }
    });
  }
</script>
