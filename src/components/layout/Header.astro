---
interface Props {
  isHome?: boolean;
}
const { isHome = false } = Astro.props;

const navLinks = [
  { name: 'About', href: '/about/' },
  { name: 'Writing', href: '/writing/' },
  { name: 'Projects', href: '/projects/' },
  { name: 'DJ', href: '/dj/' },
];
---

<header class="py-6 font-semibold text-neutral-900 dark:text-neutral-100 sm:py-10 print:hidden">
  <nav class="flex items-center justify-between">
    <!-- Avatar + site title -->
    <div class="flex flex-row items-center gap-4">
      <a href="/" aria-label="Home">
        <img
          src="/images/myhead-charcoal.png"
          alt="Jonathan Peterson"
          class="jp-avatar"
        />
      </a>
      <span style="padding-left: 0.75rem">
        <a href="/" class="text-lg font-bold text-neutral-900 dark:text-neutral-100">
          Jonathan Peterson
        </a>
      </span>
    </div>

    <!-- Main nav -->
    <ul class="flex list-none flex-col text-end sm:flex-row gap-0 sm:gap-6">
      {navLinks.map(link => (
        <li>
          <a href={link.href} class="text-sm font-semibold text-neutral-700 dark:text-neutral-300 hover:text-neutral-900 dark:hover:text-neutral-100">
            {link.name}
          </a>
        </li>
      ))}
      <!-- Dark mode toggle -->
      <li>
        <button
          id="theme-toggle"
          type="button"
          aria-label="Toggle dark mode"
          class="text-sm font-semibold text-neutral-700 dark:text-neutral-300 hover:text-neutral-900 dark:hover:text-neutral-100 cursor-pointer"
        >
          <span class="dark:hidden">☾</span>
          <span class="hidden dark:inline">☀</span>
        </button>
      </li>
    </ul>
  </nav>

  {isHome && (
    <p class="jp-hero-tagline">Product leader. Frustrated artist. Engineer at heart. Enthusiastic DJ for the afterparty.</p>
  )}
</header>

<script>
  const btn = document.getElementById('theme-toggle');
  if (btn) {
    btn.addEventListener('click', () => {
      const html = document.documentElement;
      if (html.classList.contains('dark')) {
        html.classList.remove('dark');
        localStorage.setItem('theme', 'light');
      } else {
        html.classList.add('dark');
        localStorage.setItem('theme', 'dark');
      }
    });
  }
</script>
