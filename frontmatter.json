{
  "$schema": "https://frontmatter.codes/frontmatter.schema.json",
  "frontMatter.framework.id": "astro",
  "frontMatter.preview.host": "http://localhost:4321",
  "frontMatter.content.publicFolder": {
    "path": "public",
    "relative": true
  },
  "frontMatter.content.pageFolders": [
    {
      "title": "Guides",
      "path": "[[workspace]]/src/content/docs/guides",
      "previewPath": "guides"
    },
    {
      "title": "References",
      "path": "[[workspace]]/src/content/docs/reference",
      "previewPath": "reference"
    },
    {
      "title": "templates",
      "path": "[[workspace]]/.frontmatter/templates"
    },
    {
      "title": "writing",
      "path": "[[workspace]]/src/content/writing"
    },
    {
      "title": "dj",
      "path": "[[workspace]]/src/content/dj"
    },
    {
      "title": "pages",
      "path": "[[workspace]]/src/content/pages"
    },
    {
      "title": "personal",
      "path": "[[workspace]]/src/content/writing/personal"
    },
    {
      "title": "history",
      "path": "[[workspace]]/src/content/writing/history"
    }
  ],
  "frontMatter.taxonomy.contentTypes": [
    {
      "name": "writing",
      "pageBundle": false,
      "clearEmpty": true,
      "fields": [
        {
          "name": "title",
          "type": "string",
          "single": true,
          "required": true
        },
        {
          "name": "description",
          "type": "string",
          "single": true,
          "required": true
        },
        {
          "name": "date",
          "type": "datetime",
          "required": true
        },
        {
          "name": "tags",
          "type": "tags",
          "required": true
        }
      ]
    },
    {
      "name": "dj",
      "pageBundle": false,
      "clearEmpty": true,
      "fields": [
        {
          "name": "title",
          "type": "string",
          "single": true,
          "required": true
        },
        {
          "name": "description",
          "type": "string",
          "single": true,
          "required": true
        },
        {
          "name": "date",
          "type": "datetime",
          "required": true
        },
        {
          "name": "tags",
          "type": "tags",
          "required": true
        }
      ]
    },
    {
      "name": "pages",
      "previewPath": "'pages'",
      "pageBundle": false,
      "clearEmpty": true,
      "fields": [
        {
          "name": "title",
          "type": "string",
          "single": true,
          "required": true
        },
        {
          "name": "description",
          "type": "string",
          "single": true
        },
        {
          "name": "date",
          "type": "datetime",
          "default": "{{now}}"
        },
        {
          "name": "banner",
          "type": "string",
          "single": true
        }
      ]
    }
  ],
  "frontMatter.git.enabled": true,
  "frontMatter.website.host": "jonathan-peterson.com"
}